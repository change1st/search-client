{
  "name": "search-client",
  "version": "1.0.13",
  "description": "ES/OpenSearch查询工具 - Mac客户端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "sync-icons": "true",
    "build": "npm run sync-icons && electron-builder",
    "package-mac": "npm run sync-icons && electron-builder --mac"
  },
  "keywords": [
    "elasticsearch",
    "opensearch",
    "mac",
    "client",
    "query",
    "search"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.esopensearch.client",
    "productName": "search-client",
    "icon": "assets/icon.icns",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!.venv/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^13.6.9",
    "electron-builder": "^22.14.13"
  },
  "dependencies": {
    "electron-is-dev": "^1.2.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  }
}
